# Copy to backend/.env and fill values

PORT=5000
CORS_ORIGIN=http://localhost:8080

# MongoDB connection string (Atlas free tier works great)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/atelier?retryWrites=true&w=majority
MONGODB_URI=

# Long random string used to sign JWTs (keep secret)
JWT_SECRET=

# xAI Grok
GROK_API_KEY=
