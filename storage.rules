rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // wardrobe/{uid}/* and current-photos/{uid}/*
    match /{folder}/{uid}/{file=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid
        && (folder == "wardrobe" || folder == "current-photos");
    }
  }
}
